# Скопируй в .env и подставь свой ключ.
# Нужен для: загрузки данных (download_data), проверки API Finam (finam_test_account.py, finam_mts_trade.py).

FINAM_API_KEY=
# Или отдельный токен для торговли (если отличается):
# FINAM_TRADE_TOKEN=

# Если GET /v1/accounts даёт 404 — укажи номер счёта из ЛК для проверки по счёту:
# FINAM_ACCOUNT_ID=номер_счёта_без_префикса_КлФ
